# Atticus environment configuration — copy to .env and fill in.
# NEVER commit the real .env (it is gitignored).

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Database ---
# Postgres credentials live here only; docker-compose references them via ${POSTGRES_*}.
POSTGRES_DB=atticus
POSTGRES_USER=atticus
POSTGRES_PASSWORD=atticus_dev
# Host-side connection string (the app container overrides the host to "db").
DATABASE_URL=postgresql://atticus:atticus_dev@localhost:5432/atticus

# --- USPTO Open Data Portal (register at https://data.uspto.gov) ---
USPTO_API_KEY=your-key-from-data.uspto.gov

# --- Models ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
GENERATION_MODEL=claude-sonnet-4-6
VERIFICATION_MODEL=claude-haiku-4-5

# --- App ---
LOG_LEVEL=INFO
AUDIT_TRAIL_ENABLED=true
